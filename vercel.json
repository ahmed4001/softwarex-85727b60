{
  "buildCommand": "if [ \"$VERCEL_ENV\" = \"production\" ]; then npx playwright install --with-deps chromium && npm run build:prerender; else npm run build; fi",
  "redirects": [
    { "source": "/:path*", "has": [{ "type": "host", "value": "www.reviewhunts.com" }], "destination": "https://reviewhunts.com/:path*", "permanent": true },
    { "source": "/the-lord-of-the-rings-the-rings-of-power", "destination": "/", "permanent": true },
    { "source": "/the-lord-of-the-rings-the-rings-of-power/", "destination": "/", "permanent": true },
    { "source": "/jack-ryan-season-3-trailer-release-date-cast", "destination": "/", "permanent": true },
    { "source": "/jack-ryan-season-3-trailer-release-date-cast/", "destination": "/", "permanent": true },
    { "source": "/creed-3-casting-date-of-release-and-more", "destination": "/", "permanent": true },
    { "source": "/creed-3-casting-date-of-release-and-more/", "destination": "/", "permanent": true },
    { "source": "/avatar-the-way-of-water-release-date-story-trailer", "destination": "/", "permanent": true },
    { "source": "/avatar-the-way-of-water-release-date-story-trailer/", "destination": "/", "permanent": true },
    { "source": "/enola-holmes-2-release-date-casting-plot-and-more", "destination": "/", "permanent": true },
    { "source": "/enola-holmes-2-release-date-casting-plot-and-more/", "destination": "/", "permanent": true },
    { "source": "/episode-6-house-of-the-dragon-shows-brand-new", "destination": "/", "permanent": true },
    { "source": "/episode-6-house-of-the-dragon-shows-brand-new/", "destination": "/", "permanent": true },
    { "source": "/redmi-note-12-series-by-xiaomi-debuts-in-china", "destination": "/", "permanent": true },
    { "source": "/redmi-note-12-series-by-xiaomi-debuts-in-china/", "destination": "/", "permanent": true },
    { "source": "/galaxy-m32-prime-edition-4g-smartphone", "destination": "/", "permanent": true },
    { "source": "/galaxy-m32-prime-edition-4g-smartphone/", "destination": "/", "permanent": true },
    { "source": "/vivo-t1-5g-reviews-and-specification", "destination": "/", "permanent": true },
    { "source": "/vivo-t1-5g-reviews-and-specification/", "destination": "/", "permanent": true },
    { "source": "/yamaha-earbuds-review", "destination": "/", "permanent": true },
    { "source": "/yamaha-earbuds-review/", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/sitemap-blog.xml", "destination": "https://ffeimjfunghzxgeqiwma.supabase.co/functions/v1/sitemap-dynamic?type=blog" },
    { "source": "/sitemap-guides.xml", "destination": "https://ffeimjfunghzxgeqiwma.supabase.co/functions/v1/sitemap-dynamic?type=guides" },
    { "source": "/sitemap-glossary.xml", "destination": "https://ffeimjfunghzxgeqiwma.supabase.co/functions/v1/sitemap-dynamic?type=glossary" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" },
        { "key": "X-Robots-Tag", "value": "index, follow, max-image-preview:large, max-snippet:160" }
      ]
    },
    {
      "source": "/(sitemap.*\\.xml|feed\\.xml|opensearch\\.xml)",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(llms\\.txt|llms-full\\.txt|ai\\.txt|robots\\.txt)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/(product|blog|guides)/(.*)\\.md",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" },
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|otf|eot)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)\\.(js|mjs|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
